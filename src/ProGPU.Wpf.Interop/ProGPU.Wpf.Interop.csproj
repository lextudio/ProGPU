<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <PackageId>LibreWPF.Interop</PackageId>
    <PackageDescription>LibreWPF portable interop contracts consumed by the ProGPU/Silk.NET SDK lane.</PackageDescription>
    <PackageTags>librewpf;progpu;webgpu;silk.net;interop</PackageTags>
    <SignAssembly>true</SignAssembly>
    <AssemblyOriginatorKeyFile>..\..\eng\ProGPU.snk</AssemblyOriginatorKeyFile>
  </PropertyGroup>
</Project>
